{
  "name": "@opslane/sdk",
  "version": "1.1.0",
  "type": "module",
  "description": "Browser error monitoring SDK for Opslane",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/opslane/opslane-oss.git",
    "directory": "packages/sdk"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./vite-plugin": {
      "types": "./dist/vite-plugin.d.ts",
      "import": "./dist/vite-plugin.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:package": "node scripts/check-package.mjs",
    "prepublishOnly": "vite build && node scripts/check-package.mjs"
  },
  "dependencies": {
    "rrweb": "2.1.0"
  },
  "devDependencies": {
    "@rrweb/types": "2.1.0",
    "@opslane/shared": "workspace:*",
    "@playwright/test": "^1.61.1",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-vue": "^6.0.8",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "vue": "^3.5.40",
    "jsdom": "^28.0.0",
    "typescript": "^5.4.0",
    "vite": "^6.4.3",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "vite": "^6.0.0 || ^7.0.0",
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  }
}
