{
  "name": "@opslane/agent-core",
  "version": "0.0.1",
  "description": "Provider-neutral agent loop and safe local tools for Opslane",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/__tests__",
    "!dist/**/*.test.*"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "3.0.14",
    "@anthropic-ai/sdk": "0.112.4",
    "ai": "7.0.34"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.4.0",
    "vitest": "^3.2.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
