# Opslane local environment — copy to .env and fill in what you need.
#
#   cp .env.example .env
#   docker compose up -d
#
# Everything is optional: with no .env at all, `docker compose up` runs the
# full stack and investigations end in `needs_human` with a clear reason.
# Full variable reference (drift-checked against code in CI):
#   docs/reference/environment-variables.md

# ---------------------------------------------------------------------------
# Full error-to-PR pipeline (worker)
# ---------------------------------------------------------------------------

# Claude API key. Missing -> investigations end with `missing_llm_key`.
ANTHROPIC_API_KEY=

# E2B sandbox key, used to verify fixes before a PR is opened.
E2B_API_KEY=

# GitHub access for clone + PR. Provide EITHER a PAT...
GITHUB_TOKEN=
# ...OR GitHub App credentials (also used by ingestion for webhooks/installs).
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# ---------------------------------------------------------------------------
# Dashboard sign-in (ingestion)
# ---------------------------------------------------------------------------

# `github` (default) or `workos`. Partial WorkOS config fails boot.
AUTH_PROVIDER=github
AUTH_CALLBACK_ORIGIN=http://localhost:8082
DASHBOARD_ORIGIN=http://localhost:8082

# Reader-facing dashboard base URL for incident links created by the worker and
# notification dispatcher. This must be an explicit, non-loopback HTTP(S) URL;
# it is distinct from the ingestion service's DASHBOARD_ORIGIN CORS and OAuth
# setting, which is not used as a fallback.
#DASHBOARD_URL=https://opslane.example.com

# GitHub OAuth (when AUTH_PROVIDER=github)
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=

# WorkOS AuthKit (when AUTH_PROVIDER=workos)
WORKOS_API_KEY=
WORKOS_CLIENT_ID=

# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------

# Host port for the ingestion API + dashboard (default 8082).
#INGESTION_PORT=8082

# Comma-separated operator emails for the cross-tenant admin dashboard.
# Empty disables the admin API.
#OPSLANE_ADMIN_EMAILS=

# Shared secret for worker-to-ingestion replay reads (Compose defaults to
# `dev-internal-token`; set your own outside local dev).
#INTERNAL_READ_TOKEN=

# Key for encrypted credential storage.
#ENCRYPTION_KEY=

# Override the bundled Postgres connection string.
#OPSLANE_COMPOSE_DATABASE_URL=

# Alternate git host / API, e.g. self-hosted GitHub Enterprise.
#OPSLANE_GITHUB_URL=
#OPSLANE_GITHUB_API_URL=

# Alternate Claude API endpoint (used by the hermetic test harness).
#ANTHROPIC_BASE_URL=

# Development/test only: comma-separated exact host[:port] additions to the
# Slack webhook allowlist. Never set this in production.
#NOTIFY_UNSAFE_EXTRA_WEBHOOK_HOSTS=host.docker.internal:9999

# Langfuse LLM tracing.
#LANGFUSE_PUBLIC_KEY=
#LANGFUSE_SECRET_KEY=
#LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
#LANGFUSE_PROJECT_ID=
